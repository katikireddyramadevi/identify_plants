# This is a template for environment variables.
# For local development, create a file named .env and fill in the values.

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL format: postgres://user:password@host:port/dbname
# For local SQLite, leave it commented or use: sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
